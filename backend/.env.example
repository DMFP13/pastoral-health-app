# Copy this to .env and fill in values

# "development" or "production"
APP_ENV=development

# PostgreSQL in production, SQLite by default in development
# DATABASE_URL=postgresql://user:password@host:5432/pastoral_health

# Comma-separated list of allowed frontend origins (production only)
# ALLOWED_ORIGINS=https://your-app.onrender.com

# Google Places API key for vet/supplier search (optional)
# GOOGLE_PLACES_API_KEY=your_key_here

# Port (set automatically by Render)
# PORT=8000
